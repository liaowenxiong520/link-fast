<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 日志路径由启动脚本通过 -DLOG_PATH 系统属性设置，默认 ./logs -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>

    <!-- ===================== 1. 业务代码日志（cn.linkfast 包） ===================== -->
    <appender name="BUSINESS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/linkfast-business.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/linkfast-business.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================== 2. 服务器/框架日志（非 cn.linkfast 包） ===================== -->
    <appender name="SERVER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/linkfast-server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/linkfast-server.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================== 3. 控制台输出 ===================== -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- cn.linkfast 包：只输出到 BUSINESS + 控制台，additivity=false 阻止日志冒泡到 ROOT -->
    <logger name="cn.linkfast" level="INFO" additivity="false">
        <appender-ref ref="BUSINESS"/>
        <appender-ref ref="STDOUT"/>
    </logger>

    <!-- ROOT：其他所有日志（Spring/Tomcat/框架）输出到 SERVER + 控制台 -->
    <root level="INFO">
        <appender-ref ref="SERVER"/>
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
