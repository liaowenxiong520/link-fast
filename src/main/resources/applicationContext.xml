<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/tx
           http://www.springframework.org/schema/tx/spring-tx.xsd">

    <!-- 数据源配置 -->
    <context:property-placeholder location="classpath:jdbc.properties,classpath:api.properties,classpath*:test.properties" file-encoding="UTF-8" ignore-resource-not-found="true"/>

    <bean id="dataSource" class="com.alibaba.druid.pool.DruidDataSource" destroy-method="close">
        <property name="driverClassName" value="${jdbc.driver}"/>
        <property name="url" value="${jdbc.url}"/>
        <property name="username" value="${jdbc.username}"/>
        <property name="password" value="${jdbc.password}"/>

        <!-- 连接池核心配置 -->
        <property name="initialSize" value="5"/>
        <property name="minIdle" value="5"/>
        <property name="maxActive" value="20"/>
        <property name="maxWait" value="120000"/>

        <!-- 连接保活 -->
        <property name="keepAlive" value="true"/>
        <property name="keepAliveBetweenTimeMillis" value="30001"/>
        <property name="validationQuery" value="SELECT 1"/>          <!-- 轻量检测SQL -->
        <property name="validationQueryTimeout" value="3"/>          <!-- 检测SQL超时时间3秒 -->

        <!-- 连接检测策略：性能与可用性平衡 -->
        <property name="testOnBorrow" value="true"/>    <!-- 取连接时检测有效性（防止拿到死连接） -->
        <property name="testOnReturn" value="false"/>   <!-- 关闭归还连接时检测 -->
        <property name="testWhileIdle" value="true"/>   <!-- 空闲时检测（核心） -->

        <!-- 空闲连接回收：适配MySQL的wait_timeout=7200秒 -->
        <property name="timeBetweenEvictionRunsMillis" value="30000"/>
        <property name="minEvictableIdleTimeMillis" value="1800000"/>   <!-- 30分钟回收空闲连接 -->

        <!-- 防止连接泄露（批量插入易因代码问题导致连接未释放） -->
        <property name="removeAbandoned" value="true"/>         <!-- 开启泄露连接移除 -->
        <property name="removeAbandonedTimeout" value="1800"/>    <!-- 30分钟未归还的连接视为泄露 -->
        <property name="logAbandoned" value="true"/>             <!-- 记录泄露连接日志，便于排查 -->

        <!-- 容错配置：避免批量插入时连接获取失败直接中断 -->
        <property name="breakAfterAcquireFailure" value="false"/>
        <property name="maxWaitThreadCount" value="100"/>       <!-- 最大等待连接的线程数 -->
    </bean>

    <!-- JdbcTemplate配置 -->
    <bean id="jdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
        <property name="dataSource" ref="dataSource"/>
    </bean>

    <!-- 事务管理器 -->
    <bean id="transactionManager" class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
        <property name="dataSource" ref="dataSource"/>
    </bean>

    <!--启用注解事务 -->
    <tx:annotation-driven/>

</beans>