<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 测试环境日志配置 - 使用本地临时目录而不是 Tomcat 目录 -->
    
    <!-- ===================== 1. 业务代码日志 ===================== -->
    <appender name="BUSINESS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 使用系统临时目录 -->
        <file>${java.io.tmpdir}/linkfast-test/linkfast-business.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${java.io.tmpdir}/linkfast-test/linkfast-business.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>3</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================== 2. 服务器/其他日志 ===================== -->
    <appender name="SERVER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${java.io.tmpdir}/linkfast-test/linkfast-server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${java.io.tmpdir}/linkfast-test/linkfast-server.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>3</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================== 3. 控制台输出 ===================== -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 业务包日志 -->
    <logger name="cn.linkfast" level="INFO" additivity="false">
        <appender-ref ref="BUSINESS"/>
        <appender-ref ref="STDOUT"/>
    </logger>

    <!-- 根日志 -->
    <root level="INFO">
        <appender-ref ref="SERVER"/>
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
